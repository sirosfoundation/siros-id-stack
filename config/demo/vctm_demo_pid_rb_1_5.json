  "$comment": "Source: https://github.com/eu-digital-identity-wallet/eudi-doc-attestation-rulebooks-catalog/blob/3eb9add0f1e27c64464e606d5ac6007a6418e6ca/rulebooks/pid/pid-rulebook.md",
