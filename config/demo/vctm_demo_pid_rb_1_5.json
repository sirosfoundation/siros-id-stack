      "rendering": {
        "simple": {
          "logo": {
            "uri": "data:image/png;base64,"
          }
        },
        "svg_templates": [
          {
            "uri": "data:image/svg+xml;base64,",
            "properties": {
              "orientation": "landscape"
            }
          }
        ]
      }
    }
  ],
